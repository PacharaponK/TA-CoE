# MongoDB connection string (Atlas free tier or local)
MONGODB_URI=mongodb://localhost:27017/lab_queue

# Shared secret that the TA (Admin) enters to manage the queue (Phase 1 auth)
ADMIN_SECRET=changeme-admin-secret

# Port the API listens on
PORT=4000

# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGIN=http://localhost:3000
